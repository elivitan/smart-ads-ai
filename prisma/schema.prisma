// Smart Ads AI — Prisma Schema (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop])
}

model Product {
  id              String    @id
  shop            String
  title           String
  description     String    @default("") @db.Text
  handle          String    @default("")
  image           String    @default("") @db.Text
  price           String    @default("0")
  status          String    @default("ACTIVE")
  inventoryTotal  Int       @default(0)
  inStock         Boolean   @default(true)
  productType     String    @default("")
  vendor          String    @default("")
  tags            String    @default("") @db.Text
  shopifyUpdatedAt DateTime?
  syncedAt        DateTime  @default(now())
  createdAt       DateTime  @default(now())

  aiAnalysis      AiAnalysis?

  @@index([shop])
  @@index([shop, inStock])
  @@index([shop, status])
}

model AiAnalysis {
  id              String    @id @default(cuid())
  productId       String    @unique
  shop            String
  adScore         Int       @default(0)
  adStrength      String    @default("AVERAGE")
  headlines       String    @default("[]") @db.Text
  longHeadlines   String?   @default("[]") @db.Text
  descriptions    String    @default("[]") @db.Text
  keywords        String    @default("[]") @db.Text
  negativeKeywords String   @default("[]") @db.Text
  path1           String    @default("Shop")
  path2           String    @default("")
  recommendedBid  Float     @default(1.0)
  targetDemographics String @default("") @db.Text
  sitelinks       String    @default("[]") @db.Text
  competitorIntel String    @default("{}") @db.Text
  analyzedAt      DateTime  @default(now())
  productHash     String    @default("")

  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([shop])
  @@index([productId])
  @@index([shop, adScore])
}

model SyncLog {
  id          String    @id @default(cuid())
  shop        String
  type        String
  status      String
  details     String    @default("") @db.Text
  productsAffected Int  @default(0)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  error       String?   @db.Text

  @@index([shop])
  @@index([shop, type])
  @@index([startedAt])
}

model ShopSubscription {
  id              String    @id @default(cuid())
  shop            String    @unique
  plan            String    @default("free")
  status          String    @default("active")
  scanCredits     Int       @default(0)
  aiCredits       Int       @default(0)
  maxProducts     Int       @default(3)
  maxCampaigns    Int       @default(0)
  scanCountToday  Int       @default(0)
  lastScanAt      DateTime?
  apiCallsToday   Int       @default(0)
  rateLimitReset  DateTime  @default(now())
  trialEndsAt     DateTime?
  billingStartedAt DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([shop])
  @@index([plan])
}

model CampaignJob {
  id                String    @id
  shop              String
  state             String    @default("QUEUED")
  payload           String    @default("{}") @db.Text
  idempotencyKey    String    @default("")
  attempts          Int       @default(0)
  stepsJson         String    @default("[]") @db.Text
  googleCampaignId  String?
  lastError         String?   @db.Text
  lastStepAt        DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([shop])
  @@index([shop, state])
  @@index([idempotencyKey])
  @@index([state, createdAt])
}

model AiPromptLog {
  id            String    @id @default(cuid())
  shop          String
  action        String    // e.g. "analyze", "market_intel", "campaign_builder", "daily_advice", "improve"
  model         String    @default("claude-sonnet-4-20250514")
  promptTokens  Int       @default(0)
  outputTokens  Int       @default(0)
  durationMs    Int       @default(0)
  success       Boolean   @default(true)
  error         String?   @db.Text
  metadata      String    @default("{}") @db.Text  // JSON: product title, campaign type, etc.
  createdAt     DateTime  @default(now())

  @@index([shop])
  @@index([action])
  @@index([createdAt])
  @@index([shop, action, createdAt])
}

model OptimizationLog {
  id             String   @id @default(cuid())
  shop           String
  campaignId     String
  campaignName   String   @default("")
  action         String   // "pause_campaign", "adjust_budget", "pause_keyword", "enable_campaign"
  reason         String   @db.Text
  previousValue  String?  // e.g. "budget:50" or "status:ENABLED"
  newValue       String?  // e.g. "budget:35" or "status:PAUSED"
  aiGrade        String?  // A-F from getDailyAdvice
  executedBy     String   @default("auto") // "auto" or "manual"
  success        Boolean  @default(true)
  error          String?  @db.Text
  createdAt      DateTime @default(now())

  @@index([shop])
  @@index([campaignId])
  @@index([shop, createdAt])
  @@index([createdAt])
}

model UserState {
  id              String   @id @default(cuid())
  shop            String   @unique
  selectedPlan    String?
  scanCredits     Int      @default(0)
  aiCredits       Int      @default(0)
  campaignId      String?
  campaignIntent  String?  @db.Text
  lastScanProducts String? @db.Text
  lastAiResults   String?  @db.Text
  autoScanMode    String?
  showDashboard   Boolean  @default(false)
  justSubscribed  Boolean  @default(false)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())
}

model StoreProfile {
  id                  String    @id @default(cuid())
  shop                String    @unique
  profitMargin        Float?
  targetAgeMin        Int?
  targetAgeMax        Int?
  targetGender        String?   // "all" | "male" | "female"
  brandPositioning    String?   // "premium" | "value" | "eco" | "specialty"
  avgOrderValue       Float?
  shippingSpeed       String?   // "fast" | "standard" | "slow"
  uniqueSellingPoints String?   @db.Text
  competitiveEdge     String?   @db.Text
  businessGoal        String?   // "grow_sales" | "build_brand" | "clear_inventory"
  completedAt         DateTime?
  updatedAt           DateTime  @updatedAt
  createdAt           DateTime  @default(now())

  @@index([shop])
}

model CompetitorSnapshot {
  id              String   @id @default(cuid())
  shop            String
  competitorDomain String
  productCategory String   @default("")
  avgPrice        Float?
  adCount         Int      @default(0)
  estMonthlySpend Float?
  keywords        String   @default("[]") @db.Text
  strengths       String   @default("[]") @db.Text
  weaknesses      String   @default("[]") @db.Text
  createdAt       DateTime @default(now())

  @@index([shop])
  @@index([shop, competitorDomain])
  @@index([createdAt])
}

model OptimizerLearning {
  id              String   @id @default(cuid())
  shop            String
  actionType      String
  totalAttempts   Int      @default(0)
  successCount    Int      @default(0)
  failureCount    Int      @default(0)
  neutralCount    Int      @default(0)
  successRate     Float    @default(0.5)
  confidenceLevel String   @default("learning") // "learning" | "low" | "medium" | "high"
  avgImpactRoas   Float?
  lastUpdated     DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([shop, actionType])
  @@index([shop])
}

model OptimizationRecommendation {
  id             String    @id @default(cuid())
  shop           String
  campaignId     String
  campaignName   String    @default("")
  action         String
  reason         String    @db.Text
  narrative      String?   @db.Text
  previousValue  String?
  newValue       String?
  aiGrade        String?
  status         String    @default("pending") // "pending" | "approved" | "dismissed"
  outcomeChecked Boolean   @default(false)
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([shop])
  @@index([shop, status])
  @@index([campaignId])
  @@index([createdAt])
}

model CompetitorProfile {
  id                String    @id @default(cuid())
  shop              String
  competitorDomain  String
  healthScore       Int       @default(50)
  marketPosition    String    @default("unknown")
  lastWebsiteHash   String?   @db.Text
  lastPrices        String    @default("[]") @db.Text
  lastMessaging     String?   @db.Text
  lastProductCount  Int?
  adCopyHistory     String    @default("[]") @db.Text
  hiringSignal      String?
  reviewRating      Float?
  reviewCount       Int?
  reviewSentiment   String?
  shippingSpeed     String?
  returnPolicy      String?
  vulnerabilities   String    @default("[]") @db.Text
  strengths         String    @default("[]") @db.Text
  lastScrapedAt     DateTime?
  updatedAt         DateTime  @updatedAt
  createdAt         DateTime  @default(now())

  @@unique([shop, competitorDomain])
  @@index([shop])
}

model CompetitorChange {
  id                String   @id @default(cuid())
  shop              String
  competitorDomain  String
  changeType        String   // "price_change" | "messaging_change" | "product_added" | "product_removed" | "ad_copy_change" | "review_change"
  summary           String   @db.Text
  oldValue          String?  @db.Text
  newValue          String?  @db.Text
  severity          String   @default("low") // "low" | "medium" | "high"
  createdAt         DateTime @default(now())

  @@index([shop])
  @@index([shop, competitorDomain])
  @@index([createdAt])
}

model ABTest {
  id              String    @id @default(cuid())
  shop            String
  campaignId      String
  campaignName    String    @default("")
  status          String    @default("running") // "running" | "winner_found" | "cancelled"
  variations      String    @db.Text  // JSON: [{id, headlines[], descriptions[], impressions, clicks, conversions, cost, startedAt}]
  winnerId        String?
  winnerReason    String?   @db.Text
  confidenceLevel Float?
  triggerReason   String    @default("manual") // "manual" | "creative_fatigue" | "scheduled"
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([shop])
  @@index([shop, campaignId])
  @@index([status])
}

model WeeklyReport {
  id               String   @id @default(cuid())
  shop             String
  weekStart        DateTime
  weekEnd          DateTime
  reportJson       String   @db.Text
  summary          String   @db.Text
  performanceGrade String   @default("?")
  totalSpend       Float    @default(0)
  totalRevenue     Float    @default(0)
  totalActions     Int      @default(0)
  competitorChanges Int     @default(0)
  createdAt        DateTime @default(now())

  @@index([shop])
  @@index([shop, weekStart])
}

model KeywordGapAnalysis {
  id               String   @id @default(cuid())
  shop             String
  keyword          String
  source           String   // competitor domain(s)
  estimatedVolume  Int?
  competitionLevel String   @default("medium") // "low" | "medium" | "high"
  opportunityScore Int      @default(50)       // 0-100
  suggestedBid     Float?
  status           String   @default("new")    // "new" | "targeted" | "dismissed"
  createdAt        DateTime @default(now())

  @@index([shop])
  @@index([shop, opportunityScore])
}

// ═══════════════════════════════════════════════════
// 10 NEW AI ENGINES — Session 58
// ═══════════════════════════════════════════════════

// Engine 1: Self-Evolving AI — learns from its own decisions
model AiReflection {
  id                     String   @id @default(cuid())
  shop                   String
  reflectionType         String   // "weekly_reflection" | "pre_optimization" | "pattern_discovery"
  insights               String   @db.Text  // JSON: [{pattern, evidence, recommendation, confidence}]
  rulesGenerated         String   @default("[]") @db.Text  // JSON: rules the AI learned
  decisionsReviewed      Int      @default(0)
  successRateImprovement Float?
  createdAt              DateTime @default(now())

  @@index([shop])
  @@index([shop, reflectionType])
  @@index([createdAt])
}

// Engine 2: Ad Creative DNA — winning ad element analysis
model AdCreativeDNA {
  id          String   @id @default(cuid())
  shop        String
  geneType    String   // "word" | "phrase" | "structure" | "emotion" | "cta" | "number"
  geneValue   String
  occurrences Int      @default(1)
  avgCtr      Float?
  avgConvRate Float?
  avgRoas     Float?
  winRate     Float    @default(0) // % of times it appeared in top-performing ads
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([shop, geneType, geneValue])
  @@index([shop])
  @@index([shop, winRate])
}

// Engine 3: Profit Intelligence — true profit per click/conversion
model ProfitAnalysis {
  id                String   @id @default(cuid())
  shop              String
  productId         String?
  campaignId        String?
  netProfitPerClick Float?
  netProfitPerConv  Float?
  cogs              Float?
  profitScore       Int      @default(50) // 0-100
  simulationResult  String?  @db.Text  // JSON: Monte Carlo output
  pricingSuggestion String?  @db.Text  // JSON: {suggestedPrice, reason, competitorAvg}
  analyzedAt        DateTime @default(now())
  createdAt         DateTime @default(now())

  @@index([shop])
  @@index([shop, profitScore])
  @@index([productId])
}

// Engine 4: Inventory-Aware Ads — stock-based campaign control
model InventoryAlert {
  id            String   @id @default(cuid())
  shop          String
  productId     String
  productTitle  String   @default("")
  alertType     String   // "low_stock" | "overstock" | "stockout_predicted" | "throttled" | "boosted"
  currentStock  Int      @default(0)
  dailySalesRate Float?
  daysUntilOut  Int?
  actionTaken   String?  // "throttled_campaign" | "boosted_campaign" | "paused_campaign"
  campaignId    String?
  resolved      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([shop])
  @@index([shop, resolved])
  @@index([productId])
}

// Engine 5: Competitor Ad Spend Estimator
model CompetitorSpendEstimate {
  id                String   @id @default(cuid())
  shop              String
  competitorDomain  String
  estimatedMonthly  Float?
  estimatedDaily    Float?
  impressionShare   Float?   // 0-1
  overlapRate       Float?   // 0-1
  positionAboveRate Float?   // 0-1
  dataSource        String   @default("auction_insights")
  trendDirection    String   @default("stable") // "increasing" | "decreasing" | "stable"
  trendPct          Float?
  measuredAt        DateTime @default(now())
  createdAt         DateTime @default(now())

  @@index([shop])
  @@index([shop, competitorDomain])
  @@index([measuredAt])
}

// Engine 6: Buyer Psychology — emotional triggers that drive purchases
model BuyerPsychology {
  id            String   @id @default(cuid())
  shop          String
  productId     String?
  triggerType   String   // "urgency" | "social_proof" | "fear_of_missing" | "aspiration" | "trust" | "value"
  triggerPhrase String   @db.Text
  effectiveness Float?   // 0-1
  usedInAds     Int      @default(0)
  ctrWhenUsed   Float?
  createdAt     DateTime @default(now())

  @@index([shop])
  @@index([shop, triggerType])
  @@index([productId])
}

// Engine 7: Predictive Engine — sales & performance forecasting
model SalesForecast {
  id           String   @id @default(cuid())
  shop         String
  forecastType String   // "weekly" | "monthly" | "product_lifecycle" | "campaign_what_if"
  targetId     String?  // campaignId or productId
  forecastJson String   @db.Text  // JSON: {predicted, confidence, factors[], scenarios[]}
  actualValue  Float?   // filled in retrospectively
  accuracy     Float?   // measured after period ends
  periodStart  DateTime
  periodEnd    DateTime
  createdAt    DateTime @default(now())

  @@index([shop])
  @@index([shop, forecastType])
  @@index([periodStart])
}

// Engine 8: Cross-Store Intelligence — anonymous industry benchmarks
model CrossStoreInsight {
  id          String   @id @default(cuid())
  category    String   // product category
  insightType String   // "benchmark" | "trend" | "tactic"
  metric      String   // "avg_roas" | "avg_ctr" | "top_ad_format" etc.
  value       String   @db.Text  // JSON
  sampleSize  Int      @default(0)
  confidence  Float    @default(0.5)
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())

  @@index([category])
  @@index([category, insightType])
  @@index([periodStart])
}

// Engine 9: Landing Page Optimizer — ad-to-page alignment
model LandingPageAudit {
  id             String   @id @default(cuid())
  shop           String
  productId      String
  pageUrl        String   @db.Text
  alignmentScore Int      @default(50) // 0-100
  mismatches     String   @default("[]") @db.Text  // JSON: [{issue, adClaims, pageReality, impact}]
  suggestions    String   @default("[]") @db.Text  // JSON: [{suggestion, expectedImpact}]
  pageContent    String?  @db.Text
  auditedAt      DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([shop])
  @@index([shop, alignmentScore])
  @@index([productId])
}

// Engine 10: Full Funnel Orchestrator — zero-click campaign orchestration
model FunnelOrchestration {
  id               String    @id @default(cuid())
  shop             String
  productId        String?
  funnelType       String    // "single_product" | "category" | "full_store"
  status           String    @default("draft") // "draft" | "launching" | "active" | "paused" | "completed"
  campaignIds      String    @default("[]") @db.Text
  budgetAllocation String    @default("{}") @db.Text  // JSON: {campaignId: dailyBudget}
  priorityQueue    String    @default("[]") @db.Text  // JSON: [{campaignId, priority, profitScore}]
  totalDailyBudget Float     @default(0)
  lastRebalancedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([shop])
  @@index([shop, status])
}

// ═══════════════════════════════════════════════════
// 8 ADVANCED AI ENGINES — Session 59
// ═══════════════════════════════════════════════════

// Engine 11: Digital Twin Simulator — full store simulation before spending
model DigitalTwinSimulation {
  id               String   @id @default(cuid())
  shop             String
  simulationType   String   // "campaign_launch" | "budget_change" | "seasonal" | "full_store"
  inputParams      String   @db.Text  // JSON: {budget, audience, product, duration, macroFactors}
  scenarioCount    Int      @default(1000)
  predictedRevenue Float?
  predictedRoas    Float?
  confidenceLevel  Float?   // 0-1
  riskScore        Int      @default(50) // 0-100
  scenarioResults  String   @db.Text  // JSON: {p10, p25, p50, p75, p90, mean, stdDev}
  macroFactors     String?  @db.Text  // JSON: {weather, holidays, competitorActivity, seasonality}
  recommendation   String?  @db.Text  // "launch" | "wait" | "modify" + reason
  createdAt        DateTime @default(now())

  @@index([shop])
  @@index([shop, simulationType])
}

// Engine 12: Multi-Agent Bidding Syndicate — AI agents debate budget allocation
model AgentBiddingSession {
  id              String   @id @default(cuid())
  shop            String
  campaignId      String?
  sessionType     String   // "hourly_review" | "daily_rebalance" | "emergency"
  agentVotes      String   @db.Text  // JSON: [{agent, recommendation, reasoning, confidence}]
  consensusAction String?  @db.Text  // JSON: {action, budget, bidChange, reasoning}
  agentsInvolved  Int      @default(3)
  debateRounds    Int      @default(1)
  executedAction  String?  // what was actually done
  outcomeRoas     Float?   // measured after execution
  createdAt       DateTime @default(now())

  @@index([shop])
  @@index([shop, campaignId])
  @@index([createdAt])
}

// Engine 13: Weather & Event Arbitrage — real-time environmental triggers
model WeatherEventTrigger {
  id              String   @id @default(cuid())
  shop            String
  triggerType     String   // "weather" | "holiday" | "local_event" | "trend"
  triggerData     String   @db.Text  // JSON: {condition, location, severity, duration}
  affectedProducts String  @db.Text  // JSON: [{productId, relevanceScore}]
  actionTaken     String?  @db.Text  // JSON: {campaignId, budgetChange, copyChange}
  region          String?  // geo target
  impactEstimate  Float?   // estimated revenue impact
  actualImpact    Float?   // measured after event
  expiresAt       DateTime?
  createdAt       DateTime @default(now())

  @@index([shop])
  @@index([shop, triggerType])
  @@index([expiresAt])
}

// Engine 14: Review-to-Creative Pipeline — customer voice in ads
model ReviewCreativeInsight {
  id              String   @id @default(cuid())
  shop            String
  productId       String?
  sourceReviewId  String?  // Shopify review ID
  extractedPhrase String   @db.Text  // the golden quote
  sentiment       String   @default("positive") // "positive" | "neutral" | "negative"
  frequency       Int      @default(1) // how many reviews mention similar
  usedInAds       Int      @default(0)
  ctrWhenUsed     Float?
  convRateWhenUsed Float?
  adCopyGenerated String?  @db.Text  // JSON: {headlines[], descriptions[]}
  createdAt       DateTime @default(now())

  @@index([shop])
  @@index([shop, productId])
  @@index([frequency])
}

// Engine 15: Algorithmic Price-Drop & Bid Spiking — synchronized flash sales
model FlashSaleEvent {
  id              String    @id @default(cuid())
  shop            String
  productId       String
  productTitle    String    @default("")
  triggerReason   String    // "overstock" | "slow_moving" | "seasonal_end" | "competitor_undercut"
  originalPrice   Float
  salePrice       Float
  discountPct     Float     // 0-100
  budgetMultiplier Float    @default(2.0) // bid spike factor
  campaignId      String?
  adCopyOverride  String?   @db.Text  // JSON: {headlines[], descriptions[]}
  status          String    @default("pending") // "pending" | "active" | "completed" | "cancelled"
  startsAt        DateTime
  endsAt          DateTime
  unitsSold       Int       @default(0)
  revenueGenerated Float    @default(0)
  createdAt       DateTime  @default(now())

  @@index([shop])
  @@index([shop, status])
  @@index([productId])
}

// Engine 16: Silent Profit Sentinel — hourly search term guardian
model SearchTermSentinel {
  id              String   @id @default(cuid())
  shop            String
  campaignId      String
  searchTerm      String
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  cost            Float    @default(0)
  conversions     Int      @default(0)
  addToCarts      Int      @default(0)
  wasteScore      Int      @default(0)  // 0-100, higher = more waste
  actionTaken     String?  // "negative_exact" | "negative_phrase" | "flagged" | "approved"
  savedAmount     Float?   // estimated savings from blocking
  detectedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([shop])
  @@index([shop, campaignId])
  @@index([wasteScore])
}

// Engine 17: Performance Insurance — auto-pause losing campaigns
model PerformanceGuard {
  id              String   @id @default(cuid())
  shop            String
  campaignId      String
  campaignName    String   @default("")
  guardType       String   // "auto_pause" | "budget_cut" | "bid_reduction" | "alert_only"
  triggerMetric   String   // "roas_below" | "cost_above" | "ctr_below" | "conv_rate_below"
  triggerValue    Float    // the threshold that was breached
  actualValue     Float    // the actual metric value
  actionTaken     String?  @db.Text  // JSON: {action, previousBudget, newBudget, reason}
  moneySaved      Float    @default(0) // estimated savings
  wasCorrect      Boolean? // retrospective: was the pause justified?
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())

  @@index([shop])
  @@index([shop, campaignId])
  @@index([guardType])
}

// Engine 18: Supply Chain Ads — shipment-aware campaign orchestration
model SupplyChainSignal {
  id              String    @id @default(cuid())
  shop            String
  productId       String
  productTitle    String    @default("")
  signalType      String    // "shipment_incoming" | "customs_delay" | "warehouse_received" | "pre_order_ready"
  estimatedArrival DateTime?
  actualArrival   DateTime?
  quantity        Int       @default(0)
  adAction        String?   // "pre_warm" | "launch_campaign" | "pause_until_arrival" | "boost_on_arrival"
  campaignId      String?
  preWarmStarted  Boolean   @default(false)
  status          String    @default("pending") // "pending" | "in_transit" | "arrived" | "cancelled"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([shop])
  @@index([shop, status])
  @@index([productId])
  @@index([estimatedArrival])
}
